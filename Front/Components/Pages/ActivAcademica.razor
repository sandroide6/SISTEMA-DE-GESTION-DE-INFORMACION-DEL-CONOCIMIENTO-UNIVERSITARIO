@page "/dashboard/activ-academica"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Actividades Académicas</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-journal-bookmark"></i> Actividades Académicas</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro"><i class="bi bi-plus-circle"></i> Nueva</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white"><h5 class="mb-0">@(editando ? "Editar" : "Nueva") Actividad Académica</h5></div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoNombre" placeholder="Nombre de la actividad" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" @bind="campoTipo">
                                <option value="">Seleccionar...</option>
                                <option value="Teórica">Teórica</option>
                                <option value="Práctica">Práctica</option>
                                <option value="Seminario">Seminario</option>
                                <option value="Laboratorio">Laboratorio</option>
                                <option value="Proyecto">Proyecto</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Créditos</label>
                            <input type="number" class="form-control" @bind="campoNumCreditos" placeholder="Nro. créditos" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Área Formación</label>
                            <input class="form-control" @bind="campoAreaFormacion" placeholder="Ej: Básica, Profesional" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">H. Acompañadas</label>
                            <input type="number" class="form-control" @bind="campoHAcom" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">H. Independientes</label>
                            <input type="number" class="form-control" @bind="campoHIndep" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Idioma</label>
                            <input class="form-control" @bind="campoIdioma" placeholder="Ej: Español, Inglés" />
                        </div>
                        <div class="col-md-3 mb-3 d-flex align-items-end">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" @bind="campoEspejo" id="chkEspejo" />
                                <label class="form-check-label" for="chkEspejo">¿Es espejo?</label>
                            </div>
                        </div>
                        @if (campoEspejo)
                        {
                            <div class="col-md-5 mb-3">
                                <label class="form-label">Entidad Espejo</label>
                                <input class="form-control" @bind="campoEntidadEspejo" placeholder="Nombre entidad espejo" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">País Espejo</label>
                                <input class="form-control" @bind="campoPaisEspejo" placeholder="Ej: Colombia, México" />
                            </div>
                        }
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Diseño <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoDisenio" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/disenio">Diseños</a></small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">Guardar</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div><label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" /></div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>ID</th><th>Nombre</th><th>Tipo</th><th>Créditos</th><th>Área</th><th>H.Acom</th><th>H.Indep</th><th>Idioma</th><th>Espejo</th><th>Diseño</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("id")</td>
                            <td><strong>@reg.GetValueOrDefault("nombre")</strong></td>
                            <td><span class="badge bg-info text-dark">@(reg.GetValueOrDefault("tipo") ?? "—")</span></td>
                            <td>@(reg.GetValueOrDefault("num_creditos") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("area_formacion") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("h_acom") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("h_indep") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("idioma") ?? "—")</td>
                            <td>
                                @{
                                    var esEspejo = reg.GetValueOrDefault("espejo")?.ToString();
                                    <span class="badge @(esEspejo == "True" || esEspejo == "1" ? "bg-success" : "bg-secondary")">
                                        @(esEspejo == "True" || esEspejo == "1" ? "Sí" : "No")
                                    </span>
                                }
                            </td>
                            <td>@reg.GetValueOrDefault("disenio")</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else { <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay actividades académicas.</div> }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false, campoEspejo = false;
    private string mensaje = "", campoNombre = "", campoTipo = "", campoAreaFormacion = "", campoIdioma = "";
    private string campoEntidadEspejo = "", campoPaisEspejo = "";
    private int campoId = 0, campoDisenio = 0;
    private int? campoNumCreditos = null, campoHAcom = null, campoHIndep = null;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros() { cargando = true; registros = await Api.ListarAsync("activ_academicas", limite); cargando = false; }

    private void NuevoRegistro()
    {
        editando = false; campoId = 0; campoNombre = ""; campoTipo = ""; campoAreaFormacion = ""; campoIdioma = "";
        campoEntidadEspejo = ""; campoPaisEspejo = ""; campoEspejo = false;
        campoNumCreditos = null; campoHAcom = null; campoHIndep = null; campoDisenio = 0;
        mostrarFormulario = true; mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg.GetValueOrDefault("id")?.ToString(), out int i) ? i : 0;
        campoNombre = reg.GetValueOrDefault("nombre")?.ToString() ?? "";
        campoTipo = reg.GetValueOrDefault("tipo")?.ToString() ?? "";
        campoAreaFormacion = reg.GetValueOrDefault("area_formacion")?.ToString() ?? "";
        campoIdioma = reg.GetValueOrDefault("idioma")?.ToString() ?? "";
        campoEntidadEspejo = reg.GetValueOrDefault("entidad_espejo")?.ToString() ?? "";
        campoPaisEspejo = reg.GetValueOrDefault("pais_espejo")?.ToString() ?? "";
        var espejoVal = reg.GetValueOrDefault("espejo")?.ToString();
        campoEspejo = espejoVal == "True" || espejoVal == "1";
        campoNumCreditos = int.TryParse(reg.GetValueOrDefault("num_creditos")?.ToString(), out int nc) ? nc : null;
        campoHAcom = int.TryParse(reg.GetValueOrDefault("h_acom")?.ToString(), out int ha) ? ha : null;
        campoHIndep = int.TryParse(reg.GetValueOrDefault("h_indep")?.ToString(), out int hi) ? hi : null;
        campoDisenio = int.TryParse(reg.GetValueOrDefault("disenio")?.ToString(), out int d) ? d : 0;
        mostrarFormulario = true; mensaje = "";
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["nombre"] = campoNombre,
            ["tipo"] = string.IsNullOrEmpty(campoTipo) ? null : campoTipo,
            ["num_creditos"] = campoNumCreditos,
            ["area_formacion"] = string.IsNullOrEmpty(campoAreaFormacion) ? null : campoAreaFormacion,
            ["h_acom"] = campoHAcom,
            ["h_indep"] = campoHIndep,
            ["idioma"] = string.IsNullOrEmpty(campoIdioma) ? null : campoIdioma,
            ["espejo"] = campoEspejo,
            ["entidad_espejo"] = string.IsNullOrEmpty(campoEntidadEspejo) ? null : campoEntidadEspejo,
            ["pais_espejo"] = string.IsNullOrEmpty(campoPaisEspejo) ? null : campoPaisEspejo,
            ["disenio"] = campoDisenio
        };
        var r = editando ? await Api.ActualizarAsync("activ_academicas", "id", campoId.ToString(), datos) : await Api.CrearAsync("activ_academicas", datos);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var r = await Api.EliminarAsync("activ_academicas", "id", reg.GetValueOrDefault("id")?.ToString() ?? "");
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = ""; }
}
