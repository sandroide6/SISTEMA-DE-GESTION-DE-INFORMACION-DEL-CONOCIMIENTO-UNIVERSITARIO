@page "/dashboard/pasantia"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Pasantías</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-briefcase"></i> Pasantías</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro"><i class="bi bi-plus-circle"></i> Nueva</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white"><h5 class="mb-0">@(editando ? "Editar" : "Nueva") Pasantía</h5></div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoNombre" placeholder="Nombre de la pasantía" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">País</label>
                            <input class="form-control" @bind="campoPais" placeholder="Ej: Colombia" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Empresa</label>
                            <input class="form-control" @bind="campoEmpresa" placeholder="Nombre empresa" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label class="form-label">Descripción</label>
                            <textarea class="form-control" rows="3" @bind="campoDescripcion" placeholder="Descripción de la pasantía..."></textarea>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Programa <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoPrograma" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/programa">Programas</a></small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">Guardar</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div><label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" /></div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>ID</th><th>Nombre</th><th>País</th><th>Empresa</th><th>Descripción</th><th>Programa</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("id")</td>
                            <td><strong>@reg.GetValueOrDefault("nombre")</strong></td>
                            <td>@(reg.GetValueOrDefault("pais") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("empresa") ?? "—")</td>
                            <td><small class="text-muted">@TruncateText(reg.GetValueOrDefault("descripcion")?.ToString(), 60)</small></td>
                            <td>@reg.GetValueOrDefault("programa")</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else { <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay pasantías registradas.</div> }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = "", campoNombre = "", campoPais = "", campoEmpresa = "", campoDescripcion = "";
    private int campoId = 0, campoPrograma = 0;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros() { cargando = true; registros = await Api.ListarAsync("pasantia", limite); cargando = false; }

    private void NuevoRegistro()
    {
        editando = false; campoId = 0; campoNombre = ""; campoPais = ""; campoEmpresa = ""; campoDescripcion = ""; campoPrograma = 0;
        mostrarFormulario = true; mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg.GetValueOrDefault("id")?.ToString(), out int i) ? i : 0;
        campoNombre = reg.GetValueOrDefault("nombre")?.ToString() ?? "";
        campoPais = reg.GetValueOrDefault("pais")?.ToString() ?? "";
        campoEmpresa = reg.GetValueOrDefault("empresa")?.ToString() ?? "";
        campoDescripcion = reg.GetValueOrDefault("descripcion")?.ToString() ?? "";
        campoPrograma = int.TryParse(reg.GetValueOrDefault("programa")?.ToString(), out int p) ? p : 0;
        mostrarFormulario = true; mensaje = "";
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["nombre"] = campoNombre,
            ["pais"] = string.IsNullOrEmpty(campoPais) ? null : campoPais,
            ["empresa"] = string.IsNullOrEmpty(campoEmpresa) ? null : campoEmpresa,
            ["descripcion"] = string.IsNullOrEmpty(campoDescripcion) ? null : campoDescripcion,
            ["programa"] = campoPrograma
        };
        var r = editando ? await Api.ActualizarAsync("pasantia", "id", campoId.ToString(), datos) : await Api.CrearAsync("pasantia", datos);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var r = await Api.EliminarAsync("pasantia", "id", reg.GetValueOrDefault("id")?.ToString() ?? "");
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = ""; }
    private string TruncateText(string? text, int max) => text?.Length > max ? text[..max] + "..." : (text ?? "—");
}
