@page "/dashboard/pasantia"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Pasantías</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h3><i class="bi bi-briefcase me-2"></i>Gestión de Pasantías</h3>
        </div>
        <div class="col-md-4 text-end">
            @if (!mostrarFormulario)
            {
                <button class="btn btn-primary" @onclick="NuevoRegistro">
                    <i class="bi bi-plus-circle"></i> Nueva
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@(editando ? "Editar Pasantía" : "Nueva Pasantía")</h5>
            </div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="mb-3">
                        <label class="form-label">Nombre <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="campoNombre" placeholder="Nombre de la pasantía" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">País <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoPais" placeholder="Ej: Colombia" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Empresa <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoEmpresa" placeholder="Nombre empresa" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" rows="3" @bind="campoDescripcion" placeholder="Detalles de la pasantía..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Programa <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="campoIdPrograma" required>
                            <option value="">-- Seleccionar --</option>
                            @foreach (var p in programas)
                            {
                                <option value="@p["id"]">@p["nombre"]</option>
                            }
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">
                            @if (cargando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Buscar</label>
                    <input type="text" class="form-control" @bind="busqueda" @bind:event="oninput" placeholder="Nombre o país..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Límite</label>
                    <input type="number" class="form-control" @bind="limite" min="5" max="100" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-primary w-100" @onclick="CargarRegistros">
                        <i class="bi bi-arrow-clockwise"></i> Cargar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary"></div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover table-sm">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>País</th>
                        <th>Empresa</th>
                        <th>Programa</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@reg["id"]</td>
                            <td>@reg["nombre"]</td>
                            <td><small>@(reg["pais"] ?? "—")</small></td>
                            <td><small>@(reg["empresa"] ?? "—")</small></td>
                            <td><span class="badge bg-secondary">@(reg["id_programa"] ?? "—")</span></td>
                            <td>
                                <button class="btn btn-warning btn-sm me-2" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-danger btn-sm" @onclick="() => ConfirmarEliminar(reg)"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning text-center">
            <i class="bi bi-inbox"></i> No hay pasantías. @if (!mostrarFormulario) { <a href="#" @onclick="NuevoRegistro">Crear</a> }
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new(), programas = new();
    private bool cargando = true, mostrarFormulario = false, editando = false;
    private string mensaje = string.Empty, campoNombre = string.Empty, campoPais = string.Empty, campoEmpresa = string.Empty, campoDescripcion = string.Empty, campoIdPrograma = string.Empty;
    private bool exito = false;
    private int? limite = 20;
    private string busqueda = string.Empty;
    private int? registroIdOriginal = null;

    [Inject] IJSRuntime JSRuntime { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        programas = await Api.ListarAsync("programa", 200);
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        try
        {
            registros = await Api.ListarAsync("pasantia", limite);
            if (!string.IsNullOrEmpty(busqueda))
                registros = registros.Where(r =>
                    (r["nombre"]?.ToString()?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (r["pais"]?.ToString()?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false)
                ).ToList();
        }
        catch (Exception ex) { mensaje = $"Error: {ex.Message}"; exito = false; }
        finally { cargando = false; }
    }

    private void NuevoRegistro() 
    { 
        editando = false; 
        campoNombre = campoPais = campoEmpresa = campoDescripcion = campoIdPrograma = string.Empty;
        mostrarFormulario = true; 
        mensaje = string.Empty; 
    }

    private void EditarRegistro(Dictionary<string, object?> reg) 
    { 
        editando = true; 
        registroIdOriginal = (int?)reg["id"];
        campoNombre = reg["nombre"]?.ToString() ?? "";
        campoPais = reg["pais"]?.ToString() ?? "";
        campoEmpresa = reg["empresa"]?.ToString() ?? "";
        campoDescripcion = reg["descripcion"]?.ToString() ?? "";
        campoIdPrograma = reg["id_programa"]?.ToString() ?? "";
        mostrarFormulario = true; 
        mensaje = string.Empty; 
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrEmpty(campoNombre) || string.IsNullOrEmpty(campoPais) || string.IsNullOrEmpty(campoEmpresa) || string.IsNullOrEmpty(campoIdPrograma)) 
        { 
            mensaje = "Nombre, País, Empresa y Programa son requeridos."; 
            return; 
        }

        var datos = new Dictionary<string, object?>
        {
            ["nombre"] = campoNombre,
            ["pais"] = campoPais,
            ["empresa"] = campoEmpresa,
            ["descripcion"] = string.IsNullOrEmpty(campoDescripcion) ? null : campoDescripcion,
            ["id_programa"] = int.Parse(campoIdPrograma)
        };

        var resultado = editando
            ? await Api.ActualizarAsync("pasantia", "id", registroIdOriginal.ToString(), datos)
            : await Api.CrearAsync("pasantia", datos);

        exito = resultado.exito;
        mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task ConfirmarEliminar(Dictionary<string, object?> reg)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "¿Estás seguro?"))
        {
            var resultado = await Api.EliminarAsync("pasantia", "id", reg["id"]?.ToString() ?? "");
            exito = resultado.exito;
            mensaje = resultado.mensaje;
            if (exito) await CargarRegistros();
        }
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}
