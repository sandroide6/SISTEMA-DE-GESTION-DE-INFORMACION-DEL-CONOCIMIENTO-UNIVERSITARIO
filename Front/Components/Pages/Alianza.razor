@page "/dashboard/alianza"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Alianzas</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-link-45deg"></i> Gestión de Alianzas</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro">
                <i class="bi bi-plus-circle"></i> Nueva Alianza
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@(editando ? "Editar Alianza" : "Nueva Alianza")</h5>
            </div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">ID Aliado <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoAliado" placeholder="ID del aliado" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/aliado">Aliados</a></small>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">ID Departamento <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoDepartamento" placeholder="ID del departamento" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/departamento">Departamentos</a></small>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">ID Docente <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoDocente" placeholder="ID del docente" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/docente">Docentes</a></small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha Inicio</label>
                            <input type="date" class="form-control" @bind="campoFechaInicio" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha Fin</label>
                            <input type="date" class="form-control" @bind="campoFechaFin" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">
                            @if (cargando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div>
                <label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" min="5" max="200" />
            </div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>ID</th><th>Aliado</th><th>Departamento</th><th>Docente</th><th>Fecha Inicio</th><th>Fecha Fin</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("id")</td>
                            <td>@reg.GetValueOrDefault("aliado")</td>
                            <td>@reg.GetValueOrDefault("departamento")</td>
                            <td>@reg.GetValueOrDefault("docente")</td>
                            <td>@FormatDate(reg.GetValueOrDefault("fecha_inicio"))</td>
                            <td>@FormatDate(reg.GetValueOrDefault("fecha_fin"))</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-inbox"></i> No hay alianzas registradas.
            @if (Sesion.EsAdmin && !mostrarFormulario) { <a href="#" @onclick="NuevoRegistro">Crear la primera</a> }
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private int campoId = 0;
    private int campoAliado = 0;
    private int campoDepartamento = 0;
    private int campoDocente = 0;
    private DateTime? campoFechaInicio = null;
    private DateTime? campoFechaFin = null;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("alianza", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoId = 0; campoAliado = 0; campoDepartamento = 0; campoDocente = 0;
        campoFechaInicio = null; campoFechaFin = null; mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg.GetValueOrDefault("id")?.ToString(), out int i) ? i : 0;
        campoAliado = int.TryParse(reg.GetValueOrDefault("aliado")?.ToString(), out int a) ? a : 0;
        campoDepartamento = int.TryParse(reg.GetValueOrDefault("departamento")?.ToString(), out int d) ? d : 0;
        campoDocente = int.TryParse(reg.GetValueOrDefault("docente")?.ToString(), out int dc) ? dc : 0;
        campoFechaInicio = reg.GetValueOrDefault("fecha_inicio") is DateTime fi ? fi : null;
        campoFechaFin = reg.GetValueOrDefault("fecha_fin") is DateTime ff ? ff : null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["aliado"] = campoAliado,
            ["departamento"] = campoDepartamento,
            ["docente"] = campoDocente,
            ["fecha_inicio"] = campoFechaInicio?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd")
        };

        var resultado = editando
            ? await Api.ActualizarAsync("alianza", "id", campoId.ToString(), datos)
            : await Api.CrearAsync("alianza", datos);

        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg.GetValueOrDefault("id")?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("alianza", "id", id);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }

    private string FormatDate(object? val) => val is DateTime dt ? dt.ToString("dd/MM/yyyy") : (val?.ToString() ?? "—");
}
