@page "/dashboard/programa-pe"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Programa - Práctica Estrategia</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-inbox"></i> Programa - Práctica/Estrategia</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro">
                <i class="bi bi-plus-circle"></i> Nueva Relación
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white"><h5 class="mb-0">Nueva Relación</h5></div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Programa <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoPrograma" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/programa">Programas</a></small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Práctica/Estrategia <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoPracticaEstrategia" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/practica-estrategia">Prácticas</a></small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">Guardar</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div><label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" /></div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>Programa (ID)</th><th>Práctica/Estrategia (ID)</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("programa")</td>
                            <td>@reg.GetValueOrDefault("practica_estrategia")</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i> Eliminar</button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay relaciones registradas.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private int campoPrograma = 0;
    private int campoPracticaEstrategia = 0;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("programa_pe", limite);
        cargando = false;
    }

    private void NuevoRegistro() { campoPrograma = 0; campoPracticaEstrategia = 0; mostrarFormulario = true; mensaje = string.Empty; }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?> { ["programa"] = campoPrograma, ["practica_estrategia"] = campoPracticaEstrategia };
        var resultado = await Api.CrearAsync("programa_pe", datos);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string programa = reg.GetValueOrDefault("programa")?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("programa_pe", "programa", programa);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}
