@page "/dashboard/aa-rc"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Actividad Académica - Registro Calificado</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-journal-text"></i> Activ. Académica - Registro Calificado</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro">
                <i class="bi bi-plus-circle"></i> Nuevo
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@(editando ? "Editar" : "Nuevo") AA-RC</h5>
            </div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Actividad Académica <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoActivAcademica" disabled="@editando" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/activ-academica">Actividades</a></small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Código Registro Calificado <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="campoRegistroCalificado" disabled="@editando" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/registro-calificado">Registros</a></small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Componente</label>
                            <input type="text" class="form-control" @bind="campoComponente" placeholder="Ej: Humanístico" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Semestre</label>
                            <input type="number" class="form-control" @bind="campoSemestre" min="1" max="12" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">Guardar</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div><label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" /></div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>ID Actividad</th><th>Código RC</th><th>Componente</th><th>Semestre</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("activ_academicas_idcurso")</td>
                            <td>@reg.GetValueOrDefault("registro_calificado_codigo")</td>
                            <td>@(reg.GetValueOrDefault("componente") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("semestre") ?? "—")</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay registros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private int campoActivAcademica = 0;
    private string campoRegistroCalificado = "";
    private string campoComponente = "";
    private int? campoSemestre = null;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("aa_rc", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoActivAcademica = 0; campoRegistroCalificado = "";
        campoComponente = ""; campoSemestre = null; mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoActivAcademica = int.TryParse(reg.GetValueOrDefault("activ_academicas_idcurso")?.ToString(), out int a) ? a : 0;
        campoRegistroCalificado = reg.GetValueOrDefault("registro_calificado_codigo")?.ToString() ?? "";
        campoComponente = reg.GetValueOrDefault("componente")?.ToString() ?? "";
        campoSemestre = int.TryParse(reg.GetValueOrDefault("semestre")?.ToString(), out int s) ? s : null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["componente"] = string.IsNullOrEmpty(campoComponente) ? null : campoComponente,
            ["semestre"] = campoSemestre
        };

        if (editando)
        {
            var resultado = await Api.ActualizarAsync("aa_rc", "activ_academicas_idcurso", campoActivAcademica.ToString(), datos);
            exito = resultado.exito; mensaje = resultado.mensaje;
        }
        else
        {
            datos["activ_academicas_idcurso"] = campoActivAcademica;
            datos["registro_calificado_codigo"] = campoRegistroCalificado;
            var resultado = await Api.CrearAsync("aa_rc", datos);
            exito = resultado.exito; mensaje = resultado.mensaje;
        }
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string id = reg.GetValueOrDefault("activ_academicas_idcurso")?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("aa_rc", "activ_academicas_idcurso", id);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}
