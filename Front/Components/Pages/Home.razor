        <div class="container">
            <h2 class="text-center mb-5 fw-bold">Nuestros Servicios Principales</h2>
            <div class="row g-4">
                <div class="col-lg-6">
                    <div class="service-box d-flex p-4 border-start border-4 border-primary">
                        <div class="me-4">
                            <h5 class="fw-bold text-primary">Gestión de Programas Académicos</h5>
                            <p class="text-muted mb-0">Administra programas con áreas de conocimiento, enfoques de formación y niveles académicos</p>
