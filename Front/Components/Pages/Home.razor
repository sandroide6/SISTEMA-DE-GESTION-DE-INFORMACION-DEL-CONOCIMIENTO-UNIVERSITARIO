        <div class="container">
            <h2 class="text-center mb-5 fw-bold">Centro de Soporte</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card text-center border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">Documentación</h5>
                            <p class="card-text">Guías completas y manuales de uso del sistema</p>
                            <a href="#" class="btn btn-sm btn-primary">Acceder</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">Preguntas Frecuentes</h5>
                            <p class="card-text">Respuestas a las dudas más comunes</p>
                            <a href="#" class="btn btn-sm btn-primary">Ver FAQs</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="card-title fw-bold">Contacto Técnico</h5>
                            <p class="card-text">Soporte directo para problemas urgentes</p>
                            <a href="#contacto" class="btn btn-sm btn-primary">Contactar</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Contacto -->
    <section id="contacto" class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-5 fw-bold">Ponte en Contacto</h2>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3">Formulario de Contacto</h5>
                            <form>
                                <div class="mb-3">
                                    <input type="text" class="form-control" placeholder="Tu Nombre" required>
                                </div>
                                <div class="mb-3">
                                    <input type="email" class="form-control" placeholder="Tu Email" required>
                                </div>
                                <div class="mb-3">
                                    <textarea class="form-control" rows="4" placeholder="Tu Mensaje" required></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Enviar Mensaje</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-4">Información de Contacto</h5>
                            <div class="mb-4">
                                <h6 class="fw-bold">Correo Electrónico</h6>
                                <p class="text-muted">soporte@innovacioncurricular.edu</p>
                            </div>
                            <div class="mb-4">
                                <h6 class="fw-bold">Teléfono</h6>
                                <p class="text-muted">+1 (555) 123-4567</p>
                            </div>
                            <div class="mb-4">
                                <h6 class="fw-bold">Dirección</h6>
                                <p class="text-muted">Calle Principal 123, Ciudad Educativa</p>
                            </div>
                            <div>
                                <h6 class="fw-bold">Redes Sociales</h6>
                                <p>
                                    <a href="#" class="text-primary me-3">Facebook</a>
                                    <a href="#" class="text-primary me-3">Twitter</a>
                                    <a href="#" class="text-primary">LinkedIn</a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Sobre Nosotros -->
    <section id="nosotros" class="py-5">
        <div class="container">
            <h2 class="text-center mb-5 fw-bold">Sobre Nosotros</h2>
            <div class="row g-4">
                <div class="col-lg-8 mx-auto">
                    <div class="card border-0 shadow-sm">
                        <div class="card-body p-5">
                            <h5 class="fw-bold mb-3">Nuestra Historia</h5>
                            <p class="text-muted mb-4">
                                Somos una iniciativa dedicada a transformar la educación superior a través de la innovación curricular. 
                                Fundada con la misión de facilitar la creación e implementación de propuestas educativas innovadoras.
                            </p>

                            <h5 class="fw-bold mb-3 mt-4">Misión</h5>
                            <p class="text-muted mb-4">
                                Proveer herramientas y espacios para que instituciones educativas diseñen, evalúen e implementen 
                                innovaciones curriculares que mejoren la calidad y pertinencia de la educación.
                            </p>

                            <h5 class="fw-bold mb-3">Visión</h5>
                            <p class="text-muted mb-4">
                                Ser la plataforma líder en América Latina para la gestión de innovación educativa, 
                                promoviendo educación de calidad, inclusiva y transformadora.
                            </p>

                            <h5 class="fw-bold mb-3">Nuestros Valores</h5>
                            <ul class="text-muted">
                                <li><strong>Innovación:</strong> Propulsamos cambios positivos en educación</li>
                                <li><strong>Excelencia:</strong> Comprometidos con la calidad en todo lo que hacemos</li>
                                <li><strong>Colaboración:</strong> Creemos en el trabajo conjunto para lograr objetivos</li>
                                <li><strong>Transparencia:</strong> Operamos con claridad y honestidad</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 Sistema de Innovación Curricular. Todos los derechos reservados.</p>
            <p class="small text-muted mt-2">Desarrollado con dedicación a la excelencia educativa</p>
        </div>
    </footer>
