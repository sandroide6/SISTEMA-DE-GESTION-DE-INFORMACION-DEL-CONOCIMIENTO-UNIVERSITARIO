<style>
    .bg-gradient {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .hero {
        min-height: 500px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .service-box {
        border-radius: 8px;
        background: white;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .service-box:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }
</style>
