@page "/dashboard/docente-departamento"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Docente - Departamento</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-people"></i> Docente por Departamento</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro">
                <i class="bi bi-plus-circle"></i> Nuevo
            </button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@(editando ? "Editar Asignación" : "Nueva Asignación")</h5>
            </div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Docente <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoDocente" disabled="@editando" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/docente">Docentes</a></small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Departamento <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoDepartamento" disabled="@editando" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/departamento">Departamentos</a></small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Dedicación</label>
                            <select class="form-select" @bind="campoDedicacion">
                                <option value="">Seleccionar...</option>
                                <option value="Tiempo completo">Tiempo completo</option>
                                <option value="Medio tiempo">Medio tiempo</option>
                                <option value="Hora cátedra">Hora cátedra</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Modalidad</label>
                            <select class="form-select" @bind="campoModalidad">
                                <option value="">Seleccionar...</option>
                                <option value="Presencial">Presencial</option>
                                <option value="Virtual">Virtual</option>
                                <option value="Híbrido">Híbrido</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha Ingreso</label>
                            <input type="date" class="form-control" @bind="campoFechaIngreso" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Fecha Salida</label>
                            <input type="date" class="form-control" @bind="campoFechaSalida" />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">
                            @if (cargando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div>
                <label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" min="5" max="200" />
            </div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>Docente</th><th>Departamento</th><th>Dedicación</th><th>Modalidad</th><th>Fecha Ingreso</th><th>Fecha Salida</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("docente")</td>
                            <td>@reg.GetValueOrDefault("departamento")</td>
                            <td>@(reg.GetValueOrDefault("dedicacion") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("modalidad") ?? "—")</td>
                            <td>@FormatDate(reg.GetValueOrDefault("fecha_ingreso"))</td>
                            <td>@FormatDate(reg.GetValueOrDefault("fecha_salida"))</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay registros.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;
    private int campoDocente = 0;
    private int campoDepartamento = 0;
    private string campoDedicacion = "";
    private string campoModalidad = "";
    private DateTime? campoFechaIngreso = null;
    private DateTime? campoFechaSalida = null;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("docente_departamento", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false; campoDocente = 0; campoDepartamento = 0;
        campoDedicacion = ""; campoModalidad = ""; campoFechaIngreso = null; campoFechaSalida = null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoDocente = int.TryParse(reg.GetValueOrDefault("docente")?.ToString(), out int d) ? d : 0;
        campoDepartamento = int.TryParse(reg.GetValueOrDefault("departamento")?.ToString(), out int dep) ? dep : 0;
        campoDedicacion = reg.GetValueOrDefault("dedicacion")?.ToString() ?? "";
        campoModalidad = reg.GetValueOrDefault("modalidad")?.ToString() ?? "";
        campoFechaIngreso = reg.GetValueOrDefault("fecha_ingreso") is DateTime fi ? fi : null;
        campoFechaSalida = reg.GetValueOrDefault("fecha_salida") is DateTime fs ? fs : null;
        mostrarFormulario = true; mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["dedicacion"] = string.IsNullOrEmpty(campoDedicacion) ? null : campoDedicacion,
            ["modalidad"] = string.IsNullOrEmpty(campoModalidad) ? null : campoModalidad,
            ["fecha_ingreso"] = campoFechaIngreso?.ToString("yyyy-MM-dd"),
            ["fecha_salida"] = campoFechaSalida?.ToString("yyyy-MM-dd")
        };

        if (editando)
        {
            var resultado = await Api.ActualizarAsync("docente_departamento", "docente", campoDocente.ToString(), datos);
            exito = resultado.exito; mensaje = resultado.mensaje;
        }
        else
        {
            datos["docente"] = campoDocente;
            datos["departamento"] = campoDepartamento;
            var resultado = await Api.CrearAsync("docente_departamento", datos);
            exito = resultado.exito; mensaje = resultado.mensaje;
        }

        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string docente = reg.GetValueOrDefault("docente")?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("docente_departamento", "docente", docente);
        exito = resultado.exito; mensaje = resultado.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
    private string FormatDate(object? val) => val is DateTime dt ? dt.ToString("dd/MM/yyyy") : (val?.ToString() ?? "—");
}
