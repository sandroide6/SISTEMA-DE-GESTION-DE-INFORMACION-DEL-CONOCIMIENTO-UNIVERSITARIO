@page "/dashboard/registro-calificado"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Registros Calificados</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-file-earmark-check"></i> Registros Calificados</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro"><i class="bi bi-plus-circle"></i> Nuevo</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white"><h5 class="mb-0">@(editando ? "Editar" : "Nuevo") Registro Calificado</h5></div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Código <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoCodigo" disabled="@editando" placeholder="Ej: RC-2024-001" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Metodología</label>
                            <select class="form-select" @bind="campoMetodologia">
                                <option value="">Seleccionar...</option>
                                <option value="Presencial">Presencial</option>
                                <option value="Virtual">Virtual</option>
                                <option value="Distancia">Distancia</option>
                                <option value="Híbrido">Híbrido</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Tipo Titulación</label>
                            <input class="form-control" @bind="campoTipoTitulacion" placeholder="Ej: Título Profesional" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">Créditos</label>
                            <input type="number" class="form-control" @bind="campoCantCreditos" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">H. Acompañadas</label>
                            <input type="number" class="form-control" @bind="campoHoraAcom" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label">H. Independientes</label>
                            <input type="number" class="form-control" @bind="campoHoraInd" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Duración (años)</label>
                            <input type="number" class="form-control" @bind="campoDuracionAnios" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Duración (semestres)</label>
                            <input type="number" class="form-control" @bind="campoDuracionSemestres" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Fecha Inicio</label>
                            <input type="date" class="form-control" @bind="campoFechaInicio" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Fecha Fin</label>
                            <input type="date" class="form-control" @bind="campoFechaFin" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Programa <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoPrograma" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/programa">Programas</a></small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">Guardar</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div><label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" /></div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>Código</th><th>Créditos</th><th>Metodología</th><th>Tipo Titulación</th><th>Duración</th><th>Fecha Inicio</th><th>Fecha Fin</th><th>Programa</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td><span class="badge bg-success">@reg.GetValueOrDefault("codigo")</span></td>
                            <td>@(reg.GetValueOrDefault("cant_creditos") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("metodologia") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("tipo_titulacion") ?? "—")</td>
                            <td>
                                @{
                                    var anios = reg.GetValueOrDefault("duracion_anios")?.ToString();
                                    var semestres = reg.GetValueOrDefault("duracion_semestres")?.ToString();
                                    if (!string.IsNullOrEmpty(anios) || !string.IsNullOrEmpty(semestres))
                                    {
                                        <small>@(anios ?? "—") años / @(semestres ?? "—") sem.</small>
                                    }
                                    else { <span>—</span> }
                                }
                            </td>
                            <td>@FormatDate(reg.GetValueOrDefault("fecha_inicio"))</td>
                            <td>@FormatDate(reg.GetValueOrDefault("fecha_fin"))</td>
                            <td>@reg.GetValueOrDefault("programa")</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else { <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay registros calificados.</div> }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = "", campoCodigo = "", campoMetodologia = "", campoTipoTitulacion = "";
    private int campoPrograma = 0;
    private int? campoCantCreditos = null, campoHoraAcom = null, campoHoraInd = null;
    private int? campoDuracionAnios = null, campoDuracionSemestres = null;
    private DateTime? campoFechaInicio = null, campoFechaFin = null;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros() { cargando = true; registros = await Api.ListarAsync("registro_calificado", limite); cargando = false; }

    private void NuevoRegistro()
    {
        editando = false; campoCodigo = ""; campoMetodologia = ""; campoTipoTitulacion = "";
        campoCantCreditos = null; campoHoraAcom = null; campoHoraInd = null;
        campoDuracionAnios = null; campoDuracionSemestres = null;
        campoFechaInicio = null; campoFechaFin = null; campoPrograma = 0;
        mostrarFormulario = true; mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoCodigo = reg.GetValueOrDefault("codigo")?.ToString() ?? "";
        campoMetodologia = reg.GetValueOrDefault("metodologia")?.ToString() ?? "";
        campoTipoTitulacion = reg.GetValueOrDefault("tipo_titulacion")?.ToString() ?? "";
        campoCantCreditos = int.TryParse(reg.GetValueOrDefault("cant_creditos")?.ToString(), out int cc) ? cc : null;
        campoHoraAcom = int.TryParse(reg.GetValueOrDefault("hora_acom")?.ToString(), out int ha) ? ha : null;
        campoHoraInd = int.TryParse(reg.GetValueOrDefault("hora_ind")?.ToString(), out int hi) ? hi : null;
        campoDuracionAnios = int.TryParse(reg.GetValueOrDefault("duracion_anios")?.ToString(), out int da) ? da : null;
        campoDuracionSemestres = int.TryParse(reg.GetValueOrDefault("duracion_semestres")?.ToString(), out int ds) ? ds : null;
        campoFechaInicio = reg.GetValueOrDefault("fecha_inicio") is DateTime fi ? fi : null;
        campoFechaFin = reg.GetValueOrDefault("fecha_fin") is DateTime ff ? ff : null;
        campoPrograma = int.TryParse(reg.GetValueOrDefault("programa")?.ToString(), out int p) ? p : 0;
        mostrarFormulario = true; mensaje = "";
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["cant_creditos"] = campoCantCreditos,
            ["hora_acom"] = campoHoraAcom,
            ["hora_ind"] = campoHoraInd,
            ["metodologia"] = string.IsNullOrEmpty(campoMetodologia) ? null : campoMetodologia,
            ["fecha_inicio"] = campoFechaInicio?.ToString("yyyy-MM-dd"),
            ["fecha_fin"] = campoFechaFin?.ToString("yyyy-MM-dd"),
            ["duracion_anios"] = campoDuracionAnios,
            ["duracion_semestres"] = campoDuracionSemestres,
            ["tipo_titulacion"] = string.IsNullOrEmpty(campoTipoTitulacion) ? null : campoTipoTitulacion,
            ["programa"] = campoPrograma
        };
        if (!editando) datos["codigo"] = campoCodigo;
        var r = editando
            ? await Api.ActualizarAsync("registro_calificado", "codigo", campoCodigo, datos)
            : await Api.CrearAsync("registro_calificado", datos);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var r = await Api.EliminarAsync("registro_calificado", "codigo", reg.GetValueOrDefault("codigo")?.ToString() ?? "");
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = ""; }
    private string FormatDate(object? val) => val is DateTime dt ? dt.ToString("dd/MM/yyyy") : (val?.ToString() ?? "—");
}
