@page "/dashboard/reportes"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Reportes y Consultas — SIGCU</PageTitle>

<div class="container-fluid mt-3">

    <!-- Encabezado -->
    <div class="d-flex align-items-center mb-4 gap-3">
        <div style="width:48px;height:48px;background:linear-gradient(135deg,#1565c0,#6a1b9a);border-radius:12px;display:flex;align-items:center;justify-content:center;color:white;font-size:1.4rem;">
            <i class="bi bi-bar-chart-fill"></i>
        </div>
        <div>
            <h4 class="fw-bold mb-0" style="color:#1a237e;">Reportes y Consultas</h4>
            <small class="text-muted">10 consultas multitabla — mínimo 4 tablas por consulta</small>
        </div>
    </div>

    <!-- Dashboard de métricas -->
    <div class="row g-3 mb-4">
        @foreach (var m in _metricas)
        {
            <div class="col-6 col-md-3 col-lg-2">
                <div class="card border-0 shadow-sm h-100" style="border-radius:12px;border-left:4px solid @m.Color !important;">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center gap-2 mb-1">
                            <i class="bi @m.Icono" style="color:@m.Color;font-size:1.1rem;"></i>
                            <span class="text-muted" style="font-size:.75rem;">@m.Nombre</span>
                        </div>
                        <div class="fw-bold" style="font-size:1.6rem;color:#1a237e;">
                            @(m.Valor < 0 ? "…" : m.Valor.ToString())
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Selector de consultas -->
    <div class="row g-3">
        <div class="col-lg-4 col-xl-3">
            <div class="card border-0 shadow-sm" style="border-radius:12px;">
                <div class="card-header border-0 fw-semibold" style="background:#1a237e;color:white;border-radius:12px 12px 0 0;font-size:.88rem;">
                    <i class="bi bi-list-ul me-2"></i>Consultas disponibles
                </div>
                <div class="list-group list-group-flush" style="border-radius:0 0 12px 12px;">
                    @for (int i = 0; i < _consultas.Count; i++)
                    {
                        var idx = i;
                        var c = _consultas[i];
                        <button class="list-group-item list-group-item-action border-0 py-2 px-3 @(_seleccionada == idx ? "active" : "")"
                                style="font-size:.82rem;@(_seleccionada == idx ? "background:#1565c0;color:white;" : "")"
                                @onclick="() => EjecutarConsulta(idx)">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge @(_seleccionada == idx ? "bg-white text-primary" : "bg-primary")" style="font-size:.65rem;min-width:20px;">@(i+1)</span>
                                <span>@c.Titulo</span>
                            </div>
                            <div class="mt-1" style="font-size:.7rem;opacity:.75;">
                                <i class="bi bi-table me-1"></i>@c.Tablas tablas
                            </div>
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8 col-xl-9">
            <div class="card border-0 shadow-sm" style="border-radius:12px;min-height:400px;">
                @if (_seleccionada < 0)
                {
                    <div class="card-body d-flex flex-column align-items-center justify-content-center text-muted py-5">
                        <i class="bi bi-bar-chart" style="font-size:3rem;opacity:.3;"></i>
                        <p class="mt-3 mb-0">Selecciona una consulta del panel izquierdo</p>
                    </div>
                }
                else if (_cargandoConsulta)
                {
                    <div class="card-body d-flex align-items-center justify-content-center py-5">
                        <div class="spinner-border text-primary me-3"></div>
                        <span class="text-muted">Ejecutando consulta...</span>
                    </div>
                }
                else
                {
                    var consulta = _consultas[_seleccionada];
                    <div class="card-header border-0 d-flex align-items-center justify-content-between flex-wrap gap-2"
                         style="background:#f8fafc;border-radius:12px 12px 0 0;">
                        <div>
                            <h6 class="fw-bold mb-0" style="color:#1a237e;">
                                <span class="badge bg-primary me-2">@(_seleccionada+1)</span>@consulta.Titulo
                            </h6>
                            <small class="text-muted">@consulta.Descripcion</small>
                        </div>
                        <div class="d-flex gap-2 align-items-center">
                            <span class="badge" style="background:#e8f5e9;color:#2e7d32;">
                                <i class="bi bi-table me-1"></i>@consulta.Tablas tablas
                            </span>
                            @if (_resultados.Any())
                            {
                                <span class="badge" style="background:#e3f2fd;color:#1565c0;">
                                    <i class="bi bi-collection me-1"></i>@_resultados.Count registros
                                </span>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_errorConsulta))
                    {
                        <div class="card-body">
                            <div class="alert alert-danger">
                                <i class="bi bi-exclamation-triangle me-2"></i>@_errorConsulta
                            </div>
                        </div>
                    }
                    else if (!_resultados.Any())
                    {
                        <div class="card-body d-flex align-items-center justify-content-center py-5 text-muted">
                            <i class="bi bi-inbox me-2"></i>Sin resultados para esta consulta.
                        </div>
                    }
                    else
                    {
                        var columnas = _resultados.First().Keys.ToList();
                        <div style="overflow-x:auto;overflow-y:auto;max-height:520px;">
                            <table class="table table-sm table-hover mb-0 w-100" style="font-size:.8rem;min-width:100%;">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        @foreach (var col in columnas)
                                        {
                                            <th style="font-size:.72rem;padding:8px 10px;white-space:nowrap;
                                                       background:linear-gradient(90deg,#1a237e,#1565c0);">
                                                @col.Replace("_", " ").ToUpper()
                                            </th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var fila in _resultados)
                                    {
                                        <tr>
                                            @foreach (var col in columnas)
                                            {
                                                <td style="padding:5px 10px;max-width:220px;
                                                           overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"
                                                    title="@(fila.GetValueOrDefault(col)?.ToString() ?? "")">
                                                    @(fila.GetValueOrDefault(col)?.ToString() ?? "—")
                                                </td>
                                            }
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    int _seleccionada = -1;
    bool _cargandoConsulta = false;
    string _errorConsulta = "";
    List<Dictionary<string, object?>> _resultados = new();

    record Metrica(string Nombre, string Icono, string Color, int Valor);
    record Consulta(string Titulo, string Descripcion, int Tablas, string Sql);

    List<Metrica> _metricas = new()
    {
        new("Universidades",  "bi-building",       "#1565c0", -1),
        new("Facultades",     "bi-bank",            "#1976d2", -1),
        new("Programas",      "bi-mortarboard",     "#6a1b9a", -1),
        new("Docentes",       "bi-person-badge",    "#2e7d32", -1),
        new("Acreditaciones", "bi-patch-check",     "#f57c00", -1),
        new("Alianzas",       "bi-link-45deg",      "#c62828", -1),
        new("Pasantías",      "bi-briefcase",       "#00838f", -1),
        new("Reg. Calificado","bi-file-earmark-check","#558b2f",-1),
    };

    List<Consulta> _consultas = new()
    {
        new(
            "Programas, Facultades, Universidades y Acreditaciones",
            "Vista integral del programa académico con su facultad, universidad e información de acreditación",
            4,
            @"SELECT p.nombre AS Programa, p.tipo AS TipoPrograma, p.nivel AS Nivel,
                     p.ciudad AS Ciudad, p.cant_graduados AS Graduados,
                     f.nombre AS Facultad, f.tipo AS TipoFacultad,
                     u.nombre AS Universidad, u.tipo AS TipoUniversidad,
                     a.resolucion AS Acreditacion, a.tipo AS TipoAcreditacion, a.calificacion AS Calificacion,
                     CONVERT(varchar(10), a.fecha_inicio, 103) AS InicioAcreditacion,
                     CONVERT(varchar(10), a.fecha_fin, 103) AS FinAcreditacion
              FROM programa p
              INNER JOIN facultad f ON p.facultad = f.id
              INNER JOIN universidad u ON f.universidad = u.id
              LEFT JOIN acreditacion a ON a.programa = p.id
              ORDER BY u.nombre, f.nombre, p.nombre"
        ),
        new(
            "Docentes, Departamentos, Alianzas y Aliados",
            "Mapa de relaciones entre docentes, sus departamentos, alianzas estratégicas y aliados externos",
            5,
            @"SELECT d.nombre AS Docente, d.email AS Email,
                     dep.nombre AS Departamento,
                     dd.dedicacion AS Dedicacion, dd.modalidad AS Modalidad,
                     al.nombre AS Aliado, al.tipo AS TipoAliado, al.ciudad AS CiudadAliado,
                     alz.tipo AS TipoAlianza,
                     CONVERT(varchar(10), alz.fecha_inicio, 103) AS InicioAlianza,
                     CONVERT(varchar(10), alz.fecha_fin, 103) AS FinAlianza
              FROM docente d
              INNER JOIN docente_departamento dd ON d.id = dd.docente
              INNER JOIN departamento dep ON dd.departamento = dep.id
              LEFT JOIN alianza alz ON alz.docente = d.id
              LEFT JOIN aliado al ON alz.aliado = al.id
              ORDER BY d.nombre"
        ),
        new(
            "Registro Calificado, Actividades Académicas y Diseño Curricular",
            "Estructura detallada del registro calificado con todas sus actividades académicas y diseños",
            5,
            @"SELECT rc.codigo AS CodigoRC, rc.metodologia AS Metodologia,
                     rc.tipo_titulacion AS Titulacion, rc.duracion_anios AS DuracionAnios,
                     rc.cant_creditos AS CreditosRC, p.nombre AS Programa,
                     aa.nombre AS ActividadAcademica, aa.tipo AS TipoActividad,
                     aa.num_creditos AS Creditos, aa.area_formacion AS AreaFormacion,
                     aa.idioma AS Idioma, d.nombre AS Disenio,
                     aarc.componente AS Componente, aarc.semestre AS Semestre
              FROM registro_calificado rc
              INNER JOIN programa p ON rc.programa = p.id
              INNER JOIN aa_rc aarc ON aarc.registro_calificado_codigo = rc.codigo
              INNER JOIN activ_academica aa ON aarc.activ_academicas_idcurso = aa.id
              INNER JOIN disenio d ON aa.disenio = d.id
              ORDER BY rc.codigo, aarc.semestre"
        ),
        new(
            "Programas con Áreas de Conocimiento y Universidad",
            "Clasificación de programas por área de conocimiento, gran área y disciplina académica",
            5,
            @"SELECT u.nombre AS Universidad, u.tipo AS TipoUniversidad, u.ciudad AS Ciudad,
                     f.nombre AS Facultad, p.nombre AS Programa, p.nivel AS Nivel,
                     ac.gran_area AS GranArea, ac.area AS AreaConocimiento, ac.disciplina AS Disciplina
              FROM programa p
              INNER JOIN facultad f ON p.facultad = f.id
              INNER JOIN universidad u ON f.universidad = u.id
              INNER JOIN programa_ac pac ON pac.programa = p.id
              INNER JOIN area_conocimiento ac ON pac.area_conocimiento = ac.id
              ORDER BY u.nombre, p.nombre, ac.gran_area"
        ),
        new(
            "Aspectos Normativos por Programa, Facultad y Universidad",
            "Marco normativo que regula cada programa académico con su fuente y tipo de regulación",
            5,
            @"SELECT an.tipo AS TipoNorma, an.descripcion AS Norma, an.fuente AS Fuente,
                     p.nombre AS Programa, p.nivel AS Nivel, p.tipo AS TipoPrograma,
                     f.nombre AS Facultad, f.tipo AS TipoFacultad,
                     u.nombre AS Universidad
              FROM aspecto_normativo an
              INNER JOIN an_programa anp ON anp.aspecto_normativo = an.id
              INNER JOIN programa p ON anp.programa = p.id
              INNER JOIN facultad f ON p.facultad = f.id
              INNER JOIN universidad u ON f.universidad = u.id
              ORDER BY p.nombre, an.tipo"
        ),
        new(
            "Pasantías con Programa, Facultad y Universidad",
            "Directorio de pasantías empresariales e internacionales por programa académico",
            4,
            @"SELECT pa.nombre AS Pasantia, pa.empresa AS Empresa, pa.pais AS Pais,
                     pa.descripcion AS Descripcion,
                     p.nombre AS Programa, p.tipo AS TipoPrograma,
                     f.nombre AS Facultad, u.nombre AS Universidad, u.ciudad AS CiudadUniversidad
              FROM pasantia pa
              INNER JOIN programa p ON pa.programa = p.id
              INNER JOIN facultad f ON p.facultad = f.id
              INNER JOIN universidad u ON f.universidad = u.id
              ORDER BY u.nombre, p.nombre, pa.nombre"
        ),
        new(
            "Premios y Reconocimientos por Programa y Universidad",
            "Historial de premios y distinciones obtenidos por los programas académicos",
            4,
            @"SELECT pr.nombre AS Premio, pr.entidad_otorgante AS EntidadOtorgante,
                     pr.pais AS Pais, CONVERT(varchar(10), pr.fecha, 103) AS FechaPremio,
                     pr.descripcion AS Descripcion,
                     p.nombre AS Programa, p.tipo AS TipoPrograma,
                     f.nombre AS Facultad, u.nombre AS Universidad
              FROM premio pr
              INNER JOIN programa p ON pr.programa = p.id
              INNER JOIN facultad f ON p.facultad = f.id
              INNER JOIN universidad u ON f.universidad = u.id
              ORDER BY pr.fecha DESC"
        ),
        new(
            "Enfoques por Registro Calificado, Programa y Facultad",
            "Enfoques pedagógicos asociados a cada registro calificado con información del programa",
            5,
            @"SELECT e.nombre AS Enfoque, e.descripcion AS DescripcionEnfoque,
                     rc.codigo AS CodigoRC, rc.metodologia AS Metodologia,
                     rc.tipo_titulacion AS Titulacion, rc.duracion_anios AS DuracionAnios,
                     p.nombre AS Programa, f.nombre AS Facultad
              FROM enfoque e
              INNER JOIN enfoque_rc erc ON erc.enfoque = e.id
              INNER JOIN registro_calificado rc ON erc.registro_calificado = rc.codigo
              INNER JOIN programa p ON rc.programa = p.id
              INNER JOIN facultad f ON p.facultad = f.id
              ORDER BY p.nombre, e.nombre"
        ),
        new(
            "Características de Innovación por Programa, Facultad y Universidad",
            "Mapa de innovación curricular: características por tipo asociadas a cada programa",
            5,
            @"SELECT ci.nombre AS CaracteristicaInnovacion, ci.tipo AS Tipo,
                     ci.descripcion AS Descripcion,
                     p.nombre AS Programa, p.nivel AS Nivel, p.tipo AS TipoPrograma,
                     f.nombre AS Facultad, u.nombre AS Universidad
              FROM car_innovacion ci
              INNER JOIN programa_ci pci ON pci.car_innovacion = ci.id
              INNER JOIN programa p ON pci.programa = p.id
              INNER JOIN facultad f ON p.facultad = f.id
              INNER JOIN universidad u ON f.universidad = u.id
              ORDER BY u.nombre, p.nombre, ci.nombre"
        ),
        new(
            "Prácticas y Estrategias por Programa con Registro Calificado",
            "Estrategias pedagógicas aplicadas en cada programa y su vínculo con el registro calificado",
            5,
            @"SELECT pe.nombre AS PracticaEstrategia, pe.tipo AS TipoPractica,
                     pe.descripcion AS Descripcion,
                     p.nombre AS Programa, p.nivel AS Nivel,
                     f.nombre AS Facultad,
                     rc.codigo AS CodigoRC, rc.metodologia AS Metodologia,
                     rc.duracion_anios AS DuracionAnios
              FROM practica_estrategia pe
              INNER JOIN programa_pe ppe ON ppe.practica_estrategia = pe.id
              INNER JOIN programa p ON ppe.programa = p.id
              INNER JOIN facultad f ON p.facultad = f.id
              LEFT JOIN registro_calificado rc ON rc.programa = p.id
              ORDER BY p.nombre, pe.nombre"
        ),
    };

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarMetricas();
    }

    private async Task CargarMetricas()
    {
        var tablas = new[] { "universidad", "facultad", "programa", "docente", "acreditacion", "alianza", "pasantia", "registro_calificado" };
        for (int i = 0; i < tablas.Length; i++)
        {
            var r = await Api.ListarAsync(tablas[i]);
            _metricas[i] = _metricas[i] with { Valor = r.Count };
        }
        StateHasChanged();
    }

    private async Task EjecutarConsulta(int indice)
    {
        _seleccionada = indice;
        _cargandoConsulta = true;
        _errorConsulta = "";
        _resultados = new();
        StateHasChanged();

        var (datos, _, error) = await Api.EjecutarConsultaAsync(_consultas[indice].Sql);
        _resultados = datos;
        _errorConsulta = error ?? "";
        _cargandoConsulta = false;
        StateHasChanged();
    }
}
