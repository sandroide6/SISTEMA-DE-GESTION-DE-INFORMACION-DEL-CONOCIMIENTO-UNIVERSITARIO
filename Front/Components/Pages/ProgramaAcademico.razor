@page "/dashboard/programa-academico"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api

<PageTitle>Programas Académicos</PageTitle>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h3><i class="bi bi-journal-bookmark-fill me-2"></i>Gestión de Programas Académicos</h3>
        </div>
        <div class="col-md-4 text-end">
            @if (!mostrarFormulario)
            {
                <button class="btn btn-primary" @onclick="NuevoRegistro">
                    <i class="bi bi-plus-circle"></i> Nuevo
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">@(editando ? "Editar Programa" : "Nuevo Programa")</h5>
            </div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoNombre" placeholder="Ej: Ingeniería de Sistemas" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Código</label>
                            <input class="form-control" @bind="campoCodigo" placeholder="Ej: IS-001" disabled="@editando" />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" @bind="campoTipo">
                                <option value="">-- Seleccionar --</option>
                                <option value="Pregrado">Pregrado</option>
                                <option value="Especialización">Especialización</option>
                                <option value="Maestría">Maestría</option>
                                <option value="Doctorado">Doctorado</option>
                                <option value="Técnico">Técnico</option>
                                <option value="Tecnológico">Tecnológico</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Estado</label>
                            <select class="form-select" @bind="campoEstado">
                                <option value="activo">Activo</option>
                                <option value="inactivo">Inactivo</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" rows="3" @bind="campoDescripcion" placeholder="Descripción del programa..."></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Número de créditos</label>
                            <input type="number" class="form-control" @bind="campoNumCreditos" min="1" placeholder="Ej: 165" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Número de semestres</label>
                            <input type="number" class="form-control" @bind="campoNumSemestres" min="1" placeholder="Ej: 10" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Facultad</label>
                            <select class="form-select" @bind="campoIdFacultad">
                                <option value="">-- Sin asignar --</option>
                                @foreach (var f in facultades)
                                {
                                    <option value="@f["id"]">@f["nombre"]</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">
                            @if (cargando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                            Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Buscar por nombre</label>
                    <input type="text" class="form-control" @bind="busqueda" @bind:event="oninput" placeholder="Escribe para filtrar..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Límite de registros</label>
                    <input type="number" class="form-control" @bind="limite" min="5" max="100" />
                </div>
                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-outline-primary w-100" @onclick="CargarRegistros">
                        <i class="bi bi-arrow-clockwise"></i> Cargar
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @if (!cargando && registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nombre</th>
                        <th>Código</th>
                        <th>Tipo</th>
                        <th>Créditos / Semestres</th>
                        <th>Facultad</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@reg["id"]</td>
                            <td>@reg["nombre"]</td>
                            <td><span class="badge bg-info text-dark">@(reg["codigo"] ?? "N/A")</span></td>
                            <td><small>@(reg["tipo"] ?? "—")</small></td>
                            <td class="text-center">
                                <small>@(reg["num_creditos"] ?? "—") cr / @(reg["num_semestres"] ?? "—") sem</small>
                            </td>
                            <td>
                                @{ var idF = reg["id_facultad"]?.ToString() ?? "";
                                   var nombreF = facultades.FirstOrDefault(f => f["id"]?.ToString() == idF)?["nombre"]?.ToString() ?? "—"; }
                                <span class="badge bg-secondary">@nombreF</span>
                            </td>
                            <td>
                                @{ var estado = reg["estado"]?.ToString() ?? "activo";
                                   var badge  = estado == "activo" ? "bg-success" : "bg-danger"; }
                                <span class="badge @badge">@estado</span>
                            </td>
                            <td>
                                <button class="btn btn-warning btn-sm me-2" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i> Editar</button>
                                <button class="btn btn-danger btn-sm"  @onclick="() => ConfirmarEliminar(reg)"><i class="bi bi-trash"></i> Eliminar</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning text-center">
            <i class="bi bi-inbox"></i> No se encontraron programas.
            @if (!mostrarFormulario) { <a href="#" @onclick="NuevoRegistro">Crear el primero</a> }
        </div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros  = new();
    private List<Dictionary<string, object?>> facultades = new();
    private bool cargando          = true;
    private bool mostrarFormulario = false;
    private bool editando          = false;
    private string mensaje         = string.Empty;
    private bool exito             = false;
    private string campoNombre     = string.Empty;
    private string campoCodigo     = string.Empty;
    private string campoTipo       = string.Empty;
    private string campoEstado     = "activo";
    private string campoDescripcion = string.Empty;
    private int?   campoNumCreditos = null;
    private int?   campoNumSemestres = null;
    private string campoIdFacultad = string.Empty;
    private int?   limite          = 20;
    private string busqueda        = string.Empty;

    [Inject] IJSRuntime JSRuntime { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        facultades = await Api.ListarAsync("facultad", 200);
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        try
        {
            registros = await Api.ListarAsync("programa_academico", limite);
            if (!string.IsNullOrEmpty(busqueda))
                registros = registros.Where(r =>
                    r["nombre"]?.ToString()?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false
                ).ToList();
        }
        catch (Exception ex) { mensaje = $"Error al cargar: {ex.Message}"; exito = false; }
        finally { cargando = false; }
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoNombre = string.Empty;
        campoCodigo = string.Empty;
        campoTipo   = string.Empty;
        campoEstado = "activo";
        campoDescripcion  = string.Empty;
        campoNumCreditos  = null;
        campoNumSemestres = null;
        campoIdFacultad   = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoNombre      = reg["nombre"]?.ToString() ?? "";
        campoCodigo      = reg["codigo"]?.ToString() ?? "";
        campoTipo        = reg["tipo"]?.ToString() ?? "";
        campoEstado      = reg["estado"]?.ToString() ?? "activo";
        campoDescripcion = reg["descripcion"]?.ToString() ?? "";
        campoNumCreditos  = reg["num_creditos"]  is int nc ? nc : null;
        campoNumSemestres = reg["num_semestres"] is int ns ? ns : null;
        campoIdFacultad  = reg["id_facultad"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        if (string.IsNullOrEmpty(campoNombre)) { mensaje = "El nombre es requerido."; return; }

        var datos = new Dictionary<string, object?>
        {
            ["nombre"]        = campoNombre,
            ["tipo"]          = string.IsNullOrEmpty(campoTipo) ? null : campoTipo,
            ["estado"]        = campoEstado,
            ["descripcion"]   = string.IsNullOrEmpty(campoDescripcion) ? null : campoDescripcion,
            ["num_creditos"]  = campoNumCreditos,
            ["num_semestres"] = campoNumSemestres,
            ["id_facultad"]   = string.IsNullOrEmpty(campoIdFacultad) ? null : (object?)int.Parse(campoIdFacultad)
        };

        (bool exito, string mensaje) resultado;
        if (editando)
        {
            resultado = await Api.ActualizarAsync("programa_academico", "nombre", campoNombre, datos);
        }
        else
        {
            datos["codigo"] = string.IsNullOrEmpty(campoCodigo) ? null : campoCodigo;
            resultado = await Api.CrearAsync("programa_academico", datos);
        }

        exito   = resultado.exito;
        mensaje = resultado.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task ConfirmarEliminar(Dictionary<string, object?> reg)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "¿Estás seguro que deseas eliminar este programa?"))
        {
            var resultado = await Api.EliminarAsync("programa_academico", "nombre", reg["nombre"]?.ToString() ?? "");
            exito   = resultado.exito;
            mensaje = resultado.mensaje;
            if (exito) await CargarRegistros();
        }
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = string.Empty; }
}
