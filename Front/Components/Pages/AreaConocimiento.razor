@page "/dashboard/area-conocimiento"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Área de Conocimiento</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-book"></i> Área de Conocimiento</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro"><i class="bi bi-plus-circle"></i> Nuevo</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white"><h5 class="mb-0">@(editando ? "Editar" : "Nueva") Área</h5></div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Gran Área <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoGranArea" placeholder="Ej: Ciencias Naturales" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Área <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoArea" placeholder="Ej: Biología" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Disciplina <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoDisciplina" placeholder="Ej: Genética" required />
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">
                            @if (cargando) { <span class="spinner-border spinner-border-sm me-1"></span> } Guardar
                        </button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div><label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" /></div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>ID</th><th>Gran Área</th><th>Área</th><th>Disciplina</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("id")</td>
                            <td>@reg.GetValueOrDefault("gran_area")</td>
                            <td>@reg.GetValueOrDefault("area")</td>
                            <td>@reg.GetValueOrDefault("disciplina")</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else { <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay registros.</div> }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = "", campoGranArea = "", campoArea = "", campoDisciplina = "";
    private int campoId = 0;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("area_conocimiento", limite);
        cargando = false;
    }

    private void NuevoRegistro() { editando = false; campoId = 0; campoGranArea = ""; campoArea = ""; campoDisciplina = ""; mostrarFormulario = true; mensaje = ""; }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg.GetValueOrDefault("id")?.ToString(), out int i) ? i : 0;
        campoGranArea = reg.GetValueOrDefault("gran_area")?.ToString() ?? "";
        campoArea = reg.GetValueOrDefault("area")?.ToString() ?? "";
        campoDisciplina = reg.GetValueOrDefault("disciplina")?.ToString() ?? "";
        mostrarFormulario = true; mensaje = "";
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?> { ["gran_area"] = campoGranArea, ["area"] = campoArea, ["disciplina"] = campoDisciplina };
        var r = editando ? await Api.ActualizarAsync("area_conocimiento", "id", campoId.ToString(), datos) : await Api.CrearAsync("area_conocimiento", datos);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var r = await Api.EliminarAsync("area_conocimiento", "id", reg.GetValueOrDefault("id")?.ToString() ?? "");
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = ""; }
}
