@page "/dashboard/programa"
@rendermode InteractiveServer
@inject FrontBlazor_AppiGenericaCsharp.Services.ApiService Api
@inject FrontBlazor_AppiGenericaCsharp.Services.AuthSessionService Sesion
@inject NavigationManager Nav

<PageTitle>Programas</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3><i class="bi bi-mortarboard"></i> Programas Académicos</h3>
        @if (!mostrarFormulario && Sesion.EsAdmin)
        {
            <button class="btn btn-primary" @onclick="NuevoRegistro"><i class="bi bi-plus-circle"></i> Nuevo</button>
        }
    </div>

    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @if (mostrarFormulario)
    {
        <div class="card mb-4 border-primary">
            <div class="card-header bg-primary text-white"><h5 class="mb-0">@(editando ? "Editar" : "Nuevo") Programa</h5></div>
            <div class="card-body">
                <form @onsubmit="GuardarRegistro">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nombre <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="campoNombre" required />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Tipo</label>
                            <select class="form-select" @bind="campoTipo">
                                <option value="">Seleccionar...</option>
                                <option value="Pregrado">Pregrado</option>
                                <option value="Posgrado">Posgrado</option>
                                <option value="Maestría">Maestría</option>
                                <option value="Doctorado">Doctorado</option>
                                <option value="Especialización">Especialización</option>
                            </select>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Nivel</label>
                            <input class="form-control" @bind="campoNivel" placeholder="Ej: Profesional" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Ciudad</label>
                            <input class="form-control" @bind="campoCiudad" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Graduados</label>
                            <input type="number" class="form-control" @bind="campoCantGraduados" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Fecha Creación</label>
                            <input type="date" class="form-control" @bind="campoFechaCreacion" />
                        </div>
                        <div class="col-md-3 mb-3">
                            <label class="form-label">Fecha Cierre</label>
                            <input type="date" class="form-control" @bind="campoFechaCierre" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ID Facultad <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" @bind="campoFacultad" required />
                            <small class="text-muted">Ver tabla <a href="/dashboard/facultad">Facultades</a></small>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success" disabled="@cargando">Guardar</button>
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <div class="card mb-3">
        <div class="card-body d-flex gap-2 align-items-end">
            <div><label class="form-label">Límite</label>
                <input type="number" class="form-control" style="width:100px" @bind="limite" /></div>
            <button class="btn btn-outline-primary" @onclick="CargarRegistros"><i class="bi bi-arrow-clockwise"></i> Cargar</button>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></div>
    }
    else if (registros.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr><th>ID</th><th>Nombre</th><th>Tipo</th><th>Nivel</th><th>Ciudad</th><th>Graduados</th><th>Facultad</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    @foreach (var reg in registros)
                    {
                        <tr>
                            <td>@reg.GetValueOrDefault("id")</td>
                            <td><strong>@reg.GetValueOrDefault("nombre")</strong></td>
                            <td><span class="badge bg-primary">@(reg.GetValueOrDefault("tipo") ?? "—")</span></td>
                            <td>@(reg.GetValueOrDefault("nivel") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("ciudad") ?? "—")</td>
                            <td>@(reg.GetValueOrDefault("cant_graduados") ?? "—")</td>
                            <td>@reg.GetValueOrDefault("facultad")</td>
                            <td>
                                @if (Sesion.EsAdmin)
                                {
                                    <button class="btn btn-warning btn-sm me-1" @onclick="() => EditarRegistro(reg)"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => EliminarRegistro(reg)"><i class="bi bi-trash"></i></button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else { <div class="alert alert-info text-center"><i class="bi bi-inbox"></i> No hay programas.</div> }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true, mostrarFormulario = false, editando = false, exito = false;
    private string mensaje = "", campoNombre = "", campoTipo = "", campoNivel = "", campoCiudad = "";
    private int campoId = 0, campoFacultad = 0;
    private int? campoCantGraduados = null;
    private DateTime? campoFechaCreacion = null, campoFechaCierre = null;
    private int? limite = 20;

    protected override async Task OnInitializedAsync()
    {
        if (!Sesion.EstaAutenticado) { Nav.NavigateTo("/login", true); return; }
        await CargarRegistros();
    }

    private async Task CargarRegistros() { cargando = true; registros = await Api.ListarAsync("programa", limite); cargando = false; }

    private void NuevoRegistro()
    {
        editando = false; campoId = 0; campoNombre = ""; campoTipo = ""; campoNivel = ""; campoCiudad = "";
        campoCantGraduados = null; campoFechaCreacion = null; campoFechaCierre = null; campoFacultad = 0;
        mostrarFormulario = true; mensaje = "";
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoId = int.TryParse(reg.GetValueOrDefault("id")?.ToString(), out int i) ? i : 0;
        campoNombre = reg.GetValueOrDefault("nombre")?.ToString() ?? "";
        campoTipo = reg.GetValueOrDefault("tipo")?.ToString() ?? "";
        campoNivel = reg.GetValueOrDefault("nivel")?.ToString() ?? "";
        campoCiudad = reg.GetValueOrDefault("ciudad")?.ToString() ?? "";
        campoCantGraduados = int.TryParse(reg.GetValueOrDefault("cant_graduados")?.ToString(), out int g) ? g : null;
        campoFechaCreacion = reg.GetValueOrDefault("fecha_creacion") is DateTime fc ? fc : null;
        campoFechaCierre = reg.GetValueOrDefault("fecha_cierre") is DateTime ff ? ff : null;
        campoFacultad = int.TryParse(reg.GetValueOrDefault("facultad")?.ToString(), out int f) ? f : 0;
        mostrarFormulario = true; mensaje = "";
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["nombre"] = campoNombre,
            ["tipo"] = string.IsNullOrEmpty(campoTipo) ? null : campoTipo,
            ["nivel"] = string.IsNullOrEmpty(campoNivel) ? null : campoNivel,
            ["ciudad"] = string.IsNullOrEmpty(campoCiudad) ? null : campoCiudad,
            ["cant_graduados"] = campoCantGraduados,
            ["fecha_creacion"] = campoFechaCreacion?.ToString("yyyy-MM-dd"),
            ["fecha_cierre"] = campoFechaCierre?.ToString("yyyy-MM-dd"),
            ["facultad"] = campoFacultad
        };
        var r = editando ? await Api.ActualizarAsync("programa", "id", campoId.ToString(), datos) : await Api.CrearAsync("programa", datos);
        exito = r.exito; mensaje = r.mensaje;
        if (exito) { mostrarFormulario = false; await CargarRegistros(); }
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        var r = await Api.EliminarAsync("programa", "id", reg.GetValueOrDefault("id")?.ToString() ?? "");
        exito = r.exito; mensaje = r.mensaje;
        if (exito) await CargarRegistros();
    }

    private void Cancelar() { mostrarFormulario = false; mensaje = ""; }
}
