<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SIGCU — Sistema Integrado de Gestión del Conocimiento Universitario" />
    <base href="/" />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["FrontBlazor_AppiGenericaCsharp.styles.css"]" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />

    <style>
        body { font-family: 'Inter', 'Segoe UI', sans-serif; }

        /* ── Marca SIGCU ── */
        .sigcu-brand {
            display: inline-flex;
            align-items: center;
            gap: .5rem;
            text-decoration: none;
        }
        .sigcu-logo {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #1565c0, #6a1b9a);
            border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            color: white; font-size: 1.1rem; font-weight: 800;
            flex-shrink: 0;
        }
        .sigcu-text { line-height: 1.1; }
        .sigcu-text .sigcu-name { font-size: 1.1rem; font-weight: 700; color: white; letter-spacing: .5px; }
        .sigcu-text .sigcu-sub  { font-size: .62rem; color: rgba(255,255,255,.7); letter-spacing: .3px; }

        /* ── Sidebar ── */
        .sidebar { background: linear-gradient(180deg, #1a237e 0%, #283593 60%, #1565c0 100%) !important; }
        .sidebar .nav-link { color: rgba(255,255,255,.8) !important; border-radius: 8px; margin: 1px 6px; padding: 7px 12px; font-size: .88rem; transition: background .15s, color .15s; }
        .sidebar .nav-link:hover, .sidebar .nav-link.active { background: rgba(255,255,255,.15) !important; color: #fff !important; }
        .sidebar .nav-link .bi { width: 18px; display: inline-block; }
        .top-row { background: #fff; border-bottom: 1px solid #e3e8f0; color: #374151; font-size: .85rem; }
        .sidebar .badge { font-size: .6rem; }

        /* ── Tablas ── */
        .table thead.table-dark th { background: linear-gradient(90deg, #1a237e, #1565c0); border: none; font-size: .82rem; letter-spacing: .3px; }
        .table tbody tr:hover { background: #f0f4ff; }

        /* ── Botones de acción ── */
        .btn-sm.btn-warning { background: #f59e0b; border: none; color: #fff; }
        .btn-sm.btn-danger  { background: #ef4444; border: none; }

        /* ── Cards ── */
        .card { border-radius: 12px; }

        /* ── Alertas ── */
        .alert { border-radius: 10px; border: none; }
    </style>
</head>

<body>
    <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    <script src="_framework/blazor.web.js"></script>
</body>

</html>
